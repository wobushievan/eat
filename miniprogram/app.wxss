page {
  min-height: 100%;
  background: linear-gradient(180deg, #f8f2e7 0%, #f6f7ef 100%);
  color: #3f3427;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page-shell {
  min-height: 100vh;
  padding: 32rpx 28rpx 48rpx;
  box-sizing: border-box;
}

.section-gap {
  margin-top: 24rpx;
}

.muted {
  color: #8a7964;
}

.page-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
