page {
  min-height: 100%;
  background: linear-gradient(180deg, #fbf6ee 0%, #f7f1e5 52%, #eef4ef 100%);
  color: #43362c;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page-shell {
  min-height: 100vh;
  padding: 32rpx 28rpx 48rpx;
  box-sizing: border-box;
}

.section-gap {
  margin-top: 24rpx;
}

.muted {
  color: #8b7766;
}

.page-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
