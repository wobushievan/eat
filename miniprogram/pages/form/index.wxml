<view class="page page--form">
  <view class="ambient ambient--grain"></view>
  <view class="ambient ambient--salt"></view>

  <view class="card">
    <view class="field">
      <view class="field-label">1. 出生日期</view>
      <picker mode="date" value="{{formData.birthDate}}" start="1900-01-01" end="{{today}}" bindchange="onBirthDateChange">
        <view class="picker-value {{formData.birthDate ? 'picker-value--selected' : ''}}">
          {{formData.birthDate || '请选择出生日期'}}
        </view>
      </picker>
    </view>

    <view class="field">
      <view class="field-label">2. 性别</view>
      <radio-group class="radio-group" bindchange="onSexChange">
        <label class="radio-card radio-card--compact" wx:for="{{sexOptions}}" wx:key="value">
          <radio value="{{item.value}}" checked="{{formData.sex === item.value}}" color="#ec9854" />
          <text>{{item.label}}</text>
        </label>
      </radio-group>
    </view>

    <view class="field">
      <view class="field-label">3. 体型</view>
      <radio-group class="radio-group radio-group--stack" bindchange="onBodyModeChange">
        <label class="radio-card radio-card--stack" wx:for="{{bodyModeOptions}}" wx:key="value">
          <view class="radio-card__main">
            <radio value="{{item.value}}" checked="{{formData.bodyInputMode === item.value}}" color="#ec9854" />
            <text>{{item.label}}</text>
          </view>
        </label>
      </radio-group>
    </view>

    <view class="field" wx:if="{{formData.bodyInputMode === 'exact'}}">
      <view class="field-label">4. 身高体重</view>
      <view class="input-row">
        <view class="input-item">
          <view class="input-label">身高 (cm)</view>
          <input class="input-control" type="number" value="{{formData.heightCm}}" placeholder="80-230" bindinput="onHeightInput" />
        </view>
        <view class="input-item">
          <view class="input-label">体重 (kg)</view>
          <input class="input-control" type="number" value="{{formData.weightKg}}" placeholder="10-250" bindinput="onWeightInput" />
        </view>
      </view>
    </view>

    <view class="field" wx:else>
      <view class="field-label">4. 你觉得自己属于</view>
      <radio-group class="radio-group" bindchange="onBodyTypeChange">
        <label class="radio-card radio-card--compact" wx:for="{{bodyTypeOptions}}" wx:key="value">
          <radio value="{{item.value}}" checked="{{formData.bodyType === item.value}}" color="#ec9854" />
          <text>{{item.label}}</text>
        </label>
      </radio-group>
    </view>

    <view class="field">
      <view class="field-label">5. 平时活动量</view>
      <radio-group class="radio-group radio-group--stack" bindchange="onActivityChange">
        <label class="radio-card radio-card--stack radio-card--rich" wx:for="{{activityOptions}}" wx:key="value">
          <view class="radio-card__main">
            <radio value="{{item.value}}" checked="{{formData.activityLevel === item.value}}" color="#ec9854" />
            <text>{{item.label}}</text>
          </view>
          <text class="radio-card__desc">{{item.description}}</text>
        </label>
      </radio-group>
    </view>

    <view class="field">
      <view class="field-label">6. 0-17 岁，你主要在哪长大</view>
      <picker mode="selector" range="{{provinceLabelsChildhood}}" value="{{childhoodProvinceIndex}}" bindchange="onChildhoodProvinceChange">
        <view class="picker-value picker-value--selected">{{provinceLabelsChildhood[childhoodProvinceIndex]}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="field-label">7. 18 岁后，你主要住在哪</view>
      <picker mode="selector" range="{{provinceLabelsAdult}}" value="{{adultProvinceIndex}}" bindchange="onAdultProvinceChange">
        <view class="picker-value picker-value--selected">{{provinceLabelsAdult[adultProvinceIndex]}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="field-label">8A. 主食偏好</view>

      <view class="ratio-summary">
        <view class="ratio-chip ratio-chip--rice">
          <text class="ratio-chip__name">米饭</text>
          <text class="ratio-chip__value">{{ratioValue.riceRatio}}%</text>
        </view>
        <view class="ratio-chip ratio-chip--wheat">
          <text class="ratio-chip__name">面食</text>
          <text class="ratio-chip__value">{{ratioValue.wheatRatio}}%</text>
        </view>
        <view class="ratio-chip ratio-chip--tuber">
          <text class="ratio-chip__name">粗粮杂粮</text>
          <text class="ratio-chip__value">{{ratioValue.tuberRatio}}%</text>
        </view>
      </view>

      <view class="ratio-segmented" id="ratioTrack" bindtap="onRatioTrackTap">
        <view class="ratio-segmented__bar">
          <view class="ratio-segment ratio-segment--rice" style="width: {{ratioValue.riceRatio}}%;"></view>
          <view class="ratio-segment ratio-segment--wheat" style="left: {{ratioValue.riceRatio}}%; width: {{ratioValue.wheatRatio}}%;"></view>
          <view class="ratio-segment ratio-segment--tuber" style="left: {{ratioValue.riceRatio + ratioValue.wheatRatio}}%; width: {{ratioValue.tuberRatio}}%;"></view>
        </view>

        <view
          class="ratio-handle"
          style="left: {{ratioBoundaries.first}}%;"
          data-handle="first"
          catchtouchstart="onRatioHandleStart"
          catchtouchmove="onRatioHandleMove"
          catchtouchend="onRatioHandleEnd"
          catchtouchcancel="onRatioHandleEnd"
        ></view>
        <view
          class="ratio-handle"
          style="left: {{ratioBoundaries.second}}%;"
          data-handle="second"
          catchtouchstart="onRatioHandleStart"
          catchtouchmove="onRatioHandleMove"
          catchtouchend="onRatioHandleEnd"
          catchtouchcancel="onRatioHandleEnd"
        ></view>
      </view>

      <view class="ratio-hint">拖动两个分界点，调整米饭、面食和粗粮杂粮的占比。</view>
    </view>

    <view class="field">
      <view class="field-label">8B. 口味偏好</view>
      <radio-group class="radio-group" bindchange="onTasteChange">
        <label class="radio-card radio-card--compact" wx:for="{{tasteOptions}}" wx:key="value">
          <radio value="{{item.value}}" checked="{{formData.tasteLevel === item.value}}" color="#ec9854" />
          <text>{{item.label}}</text>
        </label>
      </radio-group>
    </view>

    <view class="field">
      <view class="field-label">8B. 外食频率</view>
      <radio-group class="radio-group radio-group--stack" bindchange="onEatOutChange">
        <label class="radio-card radio-card--stack radio-card--multiline radio-card--rich" wx:for="{{eatOutOptions}}" wx:key="value">
          <radio value="{{item.value}}" checked="{{formData.eatOutLevel === item.value}}" color="#ec9854" />
          <text class="radio-card__label radio-card__label--multiline">{{item.label}}</text>
        </label>
      </radio-group>
    </view>
  </view>

  <view class="error-box" wx:if="{{errorText}}">
    <text class="error-text">{{errorText}}</text>
  </view>

  <view class="action-bar">
    <button class="secondary-btn" bindtap="handleBack">返回首页</button>
    <button class="primary-btn" bindtap="handleSubmit">开始算算看</button>
  </view>
</view>
