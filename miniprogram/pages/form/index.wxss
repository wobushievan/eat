.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 24rpx 180rpx;
  padding-bottom: calc(180rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  position: relative;
  overflow: hidden;
}

.page--form {
  background:
    radial-gradient(circle at top left, rgba(245, 206, 129, 0.32), transparent 36%),
    radial-gradient(circle at 90% 18%, rgba(149, 193, 189, 0.16), transparent 24%),
    linear-gradient(180deg, #fbf6ee 0%, #f7efe2 58%, #eef4ee 100%);
}

.ambient {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(16rpx);
  pointer-events: none;
}

.ambient--grain {
  width: 240rpx;
  height: 240rpx;
  top: 100rpx;
  right: -40rpx;
  background: rgba(240, 184, 97, 0.16);
}

.ambient--salt {
  width: 200rpx;
  height: 200rpx;
  left: -56rpx;
  bottom: 220rpx;
  background: rgba(143, 191, 185, 0.14);
}

.card,
.error-box,
.action-bar {
  position: relative;
  z-index: 1;
}

.card {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 30rpx;
  padding: 24rpx;
  border: 2rpx solid rgba(233, 222, 204, 0.72);
  box-shadow: 0 18rpx 42rpx rgba(157, 127, 92, 0.12);
}

.field + .field {
  margin-top: 24rpx;
}

.field-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #3d2e24;
  margin-bottom: 14rpx;
}

.picker-value,
.input-control {
  min-height: 84rpx;
  display: flex;
  align-items: center;
  padding: 0 22rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #fffaf3 0%, #f5ead8 100%);
  border: 2rpx solid rgba(235, 220, 198, 0.76);
  color: #a39283;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker-value--selected {
  color: #2f241d;
}

.radio-group {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
}

.radio-group--stack {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.radio-card {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 84rpx;
  padding: 0 22rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #fffaf4 0%, #f6ebda 100%);
  border: 2rpx solid rgba(235, 220, 198, 0.76);
  color: #2f241d;
  font-size: 28rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 18rpx rgba(184, 156, 123, 0.08);
}

.radio-card--compact {
  min-width: 200rpx;
}

.radio-card--stack {
  display: block;
  padding: 18rpx 22rpx;
}

.radio-card--multiline {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  min-height: 0;
  padding: 18rpx 22rpx;
}

.radio-card--rich {
  background: linear-gradient(180deg, rgba(255, 249, 241, 0.98) 0%, rgba(247, 235, 219, 0.98) 100%);
}

.radio-card__main {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.radio-card__desc {
  display: block;
  margin-top: 10rpx;
  margin-left: 52rpx;
  font-size: 24rpx;
  color: #7b6a5d;
  line-height: 1.65;
}

.radio-card__label {
  line-height: 1.5;
}

.radio-card__label--multiline {
  flex: 1;
  line-height: 1.68;
}

.input-row {
  display: flex;
  gap: 14rpx;
}

.input-item {
  flex: 1;
}

.input-label {
  font-size: 24rpx;
  color: #7b695d;
  margin-bottom: 10rpx;
}

.ratio-block {
  padding: 18rpx 18rpx 14rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(235, 220, 198, 0.72);
  background: rgba(255, 250, 243, 0.82);
}

.ratio-block + .ratio-block {
  margin-top: 14rpx;
}

.ratio-block--rice {
  background: linear-gradient(180deg, rgba(255, 246, 231, 0.96) 0%, rgba(250, 234, 205, 0.92) 100%);
}

.ratio-block--wheat {
  background: linear-gradient(180deg, rgba(252, 246, 235, 0.96) 0%, rgba(244, 230, 205, 0.92) 100%);
}

.ratio-block--tuber {
  background: linear-gradient(180deg, rgba(245, 250, 247, 0.96) 0%, rgba(229, 240, 233, 0.92) 100%);
}

.ratio-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}

.ratio-name {
  font-size: 28rpx;
  color: #2f241d;
}

.ratio-value {
  font-size: 26rpx;
  font-weight: 700;
  color: #af7740;
}

.ratio-total {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #7a695d;
}

.error-box {
  margin-top: 16rpx;
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #fff5ef 0%, #ffe8de 100%);
  border: 2rpx solid rgba(241, 204, 187, 0.72);
}

.error-text {
  color: #c45f42;
  font-size: 24rpx;
  line-height: 1.6;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 14rpx;
  padding: 18rpx 24rpx 26rpx;
  padding-bottom: calc(26rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(26rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(251, 246, 238, 0.66) 0%, rgba(246, 239, 226, 0.96) 36%, rgba(245, 236, 222, 0.98) 100%);
  backdrop-filter: blur(14rpx);
  z-index: 20;
}

.primary-btn,
.secondary-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 82rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  box-sizing: border-box;
  text-align: center;
}

.primary-btn {
  background: linear-gradient(180deg, #f4ae66 0%, #e48a4f 100%);
  color: #fffaf3;
  box-shadow: 0 14rpx 28rpx rgba(201, 123, 55, 0.18);
}

.secondary-btn {
  background: rgba(255, 255, 255, 0.88);
  color: #6b594c;
  border: 2rpx solid rgba(231, 217, 197, 0.92);
  box-shadow: 0 10rpx 20rpx rgba(181, 156, 127, 0.08);
}

.primary-btn::after,
.secondary-btn::after {
  border: none;
}
