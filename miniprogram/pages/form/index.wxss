.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 40rpx 32rpx 220rpx;
  padding-bottom: calc(220rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
  background: #fff8ef;
}

.hero {
  margin-bottom: 28rpx;
}

.title {
  font-size: 48rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #2f2a24;
  margin-bottom: 16rpx;
}

.desc {
  font-size: 28rpx;
  line-height: 1.7;
  color: #7a6f63;
}

.progress-card,
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.progress-card {
  margin-bottom: 24rpx;
}

.progress-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 20rpx;
}

.progress-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2f2a24;
}

.progress-text {
  font-size: 24rpx;
  color: #7a6f63;
}

.progress-track {
  margin-top: 18rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: #f2e5d5;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #f6b26b, #f2cf74);
}

.step-pill-row {
  display: flex;
  gap: 14rpx;
  margin-top: 20rpx;
}

.step-pill {
  width: 52rpx;
  height: 52rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f9f2e8;
  color: #a39384;
  font-size: 24rpx;
  font-weight: 600;
}

.step-pill--active {
  background: #f6b26b;
  color: #ffffff;
}

.card {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2f2a24;
  margin-bottom: 8rpx;
}

.field + .field {
  margin-top: 32rpx;
}

.field-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #2f2a24;
  margin-bottom: 16rpx;
}

.picker-value {
  min-height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: #f9f2e8;
  color: #a39384;
  font-size: 28rpx;
}

.picker-value--selected {
  color: #2f2a24;
}

.radio-group {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.radio-group--stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.radio-card {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: #f9f2e8;
  color: #2f2a24;
  font-size: 28rpx;
  box-sizing: border-box;
}

.radio-card--stack {
  display: block;
  padding: 20rpx 24rpx;
}

.radio-card--multiline {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  min-height: 0;
  padding: 20rpx 24rpx;
}

.radio-card__main {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.radio-card__desc {
  display: block;
  margin-top: 12rpx;
  margin-left: 52rpx;
  font-size: 24rpx;
  color: #7a6f63;
  line-height: 1.7;
}

.radio-card__label {
  line-height: 1.5;
}

.radio-card__label--multiline {
  flex: 1;
  line-height: 1.7;
}

.input-row {
  display: flex;
  gap: 20rpx;
}

.input-item {
  flex: 1;
}

.input-label {
  font-size: 24rpx;
  color: #7a6f63;
  margin-bottom: 12rpx;
}

.input-control {
  height: 88rpx;
  border-radius: 20rpx;
  background: #f9f2e8;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #2f2a24;
  box-sizing: border-box;
}

.ratio-block + .ratio-block {
  margin-top: 24rpx;
}

.ratio-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.ratio-name {
  font-size: 28rpx;
  color: #2f2a24;
}

.ratio-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #b47b3f;
}

.ratio-total {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #7a6f63;
}

.error-box {
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  background: #fff1eb;
}

.error-text {
  color: #c45f42;
  font-size: 24rpx;
  line-height: 1.6;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx 40rpx;
  padding-bottom: calc(40rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: rgba(255, 248, 239, 0.96);
  backdrop-filter: blur(8rpx);
  z-index: 20;
}

.primary-btn,
.secondary-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  box-sizing: border-box;
  text-align: center;
}

.primary-btn {
  background: #f6b26b;
  color: #ffffff;
}

.secondary-btn {
  background: #ffffff;
  color: #6f6255;
  border: 2rpx solid #ead9c8;
}

.secondary-btn--full {
  flex: 1;
}

.primary-btn::after,
.secondary-btn::after {
  border: none;
}
