.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 20rpx 24rpx 28rpx;
  position: relative;
  overflow: hidden;
}

.page--result {
  background:
    radial-gradient(circle at top left, rgba(245, 205, 128, 0.34), transparent 34%),
    radial-gradient(circle at 92% 24%, rgba(142, 191, 188, 0.18), transparent 24%),
    linear-gradient(180deg, #fbf6ee 0%, #f6efe2 52%, #eff4ee 100%);
}

.ambient {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(16rpx);
  pointer-events: none;
}

.ambient--grain {
  width: 240rpx;
  height: 240rpx;
  top: 120rpx;
  right: -48rpx;
  background: rgba(241, 183, 93, 0.16);
}

.ambient--salt {
  width: 180rpx;
  height: 180rpx;
  left: -40rpx;
  bottom: 120rpx;
  background: rgba(139, 187, 181, 0.14);
}

.hero {
  position: relative;
  z-index: 1;
  margin-bottom: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.eyebrow,
.hero-meta {
  display: inline-flex;
  align-items: center;
  height: 40rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  font-size: 22rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(179, 145, 103, 0.1);
}

.eyebrow {
  color: #a07c54;
}

.hero-meta {
  color: #6f5d50;
}

.hero-meta--empty {
  margin: 0 auto;
}

.result-card {
  position: relative;
  z-index: 1;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 30rpx;
  padding: 22rpx;
  border: 2rpx solid rgba(233, 222, 204, 0.72);
  box-shadow: 0 18rpx 42rpx rgba(157, 127, 92, 0.12);
}

.result-card + .result-card,
.result-card + .action-row {
  margin-top: 14rpx;
}

.result-card__label {
  font-size: 24rpx;
  color: #927461;
  font-weight: 600;
}

.result-card__summary {
  margin-top: 10rpx;
  font-size: 30rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #34261f;
}

.visual-area {
  margin-top: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  border: 2rpx solid rgba(238, 226, 208, 0.84);
}

.result-card--grain .visual-area {
  background: linear-gradient(180deg, rgba(255, 248, 237, 0.96) 0%, rgba(253, 241, 219, 0.96) 100%);
}

.result-card--salt .visual-area {
  background: linear-gradient(180deg, rgba(246, 251, 250, 0.96) 0%, rgba(234, 244, 242, 0.96) 100%);
}

.visual-group + .visual-group {
  margin-top: 14rpx;
}

.visual-group__label {
  font-size: 22rpx;
  line-height: 1.5;
  color: #7a6452;
}

.icon-strip {
  margin-top: 8rpx;
}

.icon-row {
  display: flex;
  align-items: flex-end;
}

.display-icon {
  flex: 0 0 auto;
}

.display-image {
  width: 100%;
  height: 100%;
  display: block;
  filter: drop-shadow(0 8rpx 10rpx rgba(112, 88, 60, 0.1));
}

.result-total {
  margin-top: 14rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #8c7766;
}

.action-row {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 14rpx;
  margin-top: 14rpx;
}

.primary-btn,
.secondary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 78rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  border: none;
  font-size: 28rpx;
  font-weight: 700;
  box-sizing: border-box;
  text-align: center;
}

.primary-btn {
  background: linear-gradient(180deg, #f4ae66 0%, #e48a4f 100%);
  color: #fffaf3;
  box-shadow: 0 14rpx 26rpx rgba(201, 123, 55, 0.18);
}

.secondary-btn {
  background: rgba(255, 255, 255, 0.88);
  color: #6d5b4c;
  border: 2rpx solid rgba(231, 217, 197, 0.92);
  box-shadow: 0 10rpx 20rpx rgba(181, 156, 127, 0.08);
}

.primary-btn--half,
.secondary-btn--half {
  flex: 1;
}

.empty-page {
  padding-top: 120rpx;
}

.primary-btn::after,
.secondary-btn::after {
  border: none;
}
