<view class="page page--result">
  <view class="ambient ambient--grain"></view>
  <view class="ambient ambient--salt"></view>

  <view wx:if="{{!empty}}">
    <view class="hero">
      <view class="eyebrow">计算日期 {{sourceDate}}</view>
      <view class="hero-meta">{{ageText}}</view>
    </view>

    <view class="result-card result-card--grain">
      <view class="result-card__label">{{cookedCard.label}}</view>
      <view class="result-card__summary">{{cookedCard.summaryText}}</view>

      <view class="visual-area">
        <view wx:for="{{cookedCard.visualGroups}}" wx:for-item="group" wx:key="unit" class="visual-group">
          <view class="visual-group__label">{{group.title}}</view>
          <view class="icon-strip">
            <view wx:for="{{group.rows}}" wx:for-item="row" wx:key="index" class="icon-row" style="{{row.style}}">
              <view wx:for="{{row.icons}}" wx:for-item="icon" wx:key="index" class="display-icon" style="{{icon.style}}">
                <image class="display-image" src="{{group.asset}}" mode="aspectFit"></image>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="result-total">{{cookedCard.weightText}}</view>
    </view>

    <view class="result-card result-card--salt">
      <view class="result-card__label">{{saltCard.label}}</view>
      <view class="result-card__summary">{{saltCard.summaryText}}</view>

      <view class="visual-area">
        <view wx:for="{{saltCard.visualGroups}}" wx:for-item="group" wx:key="unit" class="visual-group">
          <view class="visual-group__label">{{group.title}}</view>
          <view class="icon-strip">
            <view wx:for="{{group.rows}}" wx:for-item="row" wx:key="index" class="icon-row" style="{{row.style}}">
              <view wx:for="{{row.icons}}" wx:for-item="icon" wx:key="index" class="display-icon" style="{{icon.style}}">
                <image class="display-image" src="{{group.asset}}" mode="aspectFit"></image>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="result-total">{{saltCard.weightText}}</view>
    </view>

    <view class="action-row">
      <button class="primary-btn primary-btn--half" bindtap="goEdit">重新填一遍</button>
      <button class="secondary-btn secondary-btn--half" bindtap="goAbout">看看这结果怎么算</button>
    </view>
  </view>

  <view wx:else class="empty-page">
    <view class="hero">
      <view class="hero-meta hero-meta--empty">还没有结果</view>
    </view>

    <button class="primary-btn" bindtap="goHome">返回首页</button>
  </view>
</view>
