<view class="page page--result">
  <view class="ambient ambient--grain"></view>
  <view class="ambient ambient--salt"></view>

  <view wx:if="{{!empty}}">
    <view class="hero">
      <view class="eyebrow">计算日期 {{sourceDate}}</view>
      <view class="hero-meta">{{ageText}}</view>
    </view>

    <view class="result-card result-card--grain">
      <view class="result-card__label">{{cookedCard.label}}</view>

      <view class="data-row">
        <view class="data-row__title">{{cookedCard.primaryRow.title}}</view>
        <view class="icon-strip">
          <view wx:for="{{cookedCard.primaryRow.rows}}" wx:key="index" class="icon-row" style="{{item.style}}">
            <view wx:for="{{item.icons}}" wx:key="index" class="display-icon" style="{{item.style}}">
              <image class="display-image" src="{{cookedCard.primaryRow.asset}}" mode="aspectFit"></image>
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{cookedCard.secondaryRow}}" class="data-row data-row--secondary">
        <view class="data-row__title">{{cookedCard.secondaryRow.title}}</view>
        <view class="icon-strip">
          <view wx:for="{{cookedCard.secondaryRow.rows}}" wx:key="index" class="icon-row" style="{{item.style}}">
            <view wx:for="{{item.icons}}" wx:key="index" class="display-icon" style="{{item.style}}">
              <image class="display-image" src="{{cookedCard.secondaryRow.asset}}" mode="aspectFit"></image>
            </view>
          </view>
        </view>
      </view>

      <view class="result-total">{{cookedCard.totalText}}</view>
    </view>

    <view class="result-card result-card--salt">
      <view class="result-card__label">{{saltCard.label}}</view>

      <view class="data-row">
        <view class="data-row__title">{{saltCard.primaryRow.title}}</view>
        <view class="icon-strip">
          <view wx:for="{{saltCard.primaryRow.rows}}" wx:key="index" class="icon-row" style="{{item.style}}">
            <view wx:for="{{item.icons}}" wx:key="index" class="display-icon" style="{{item.style}}">
              <image class="display-image" src="{{saltCard.primaryRow.asset}}" mode="aspectFit"></image>
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{saltCard.secondaryRow}}" class="data-row data-row--secondary">
        <view class="data-row__title">{{saltCard.secondaryRow.title}}</view>
        <view class="icon-strip">
          <view wx:for="{{saltCard.secondaryRow.rows}}" wx:key="index" class="icon-row" style="{{item.style}}">
            <view wx:for="{{item.icons}}" wx:key="index" class="display-icon" style="{{item.style}}">
              <image class="display-image" src="{{saltCard.secondaryRow.asset}}" mode="aspectFit"></image>
            </view>
          </view>
        </view>
      </view>

      <view class="result-total">{{saltCard.totalText}}</view>
    </view>

    <view class="action-row">
      <button class="primary-btn primary-btn--half" bindtap="goEdit">重新填一遍</button>
      <button class="secondary-btn secondary-btn--half" bindtap="goAbout">看看这结果怎么算</button>
    </view>
  </view>

  <view wx:else class="empty-page">
    <view class="hero">
      <view class="hero-meta hero-meta--empty">还没有结果</view>
    </view>

    <button class="primary-btn" bindtap="goHome">返回首页</button>
  </view>
</view>
