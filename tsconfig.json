{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": [
      "miniprogram-api-typings",
      "node"
    ],
    "baseUrl": "."
  },
  "include": [
    "miniprogram/**/*.ts",
    "tests/**/*.ts"
  ]
}
